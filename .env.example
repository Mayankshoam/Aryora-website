# --- Server ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# --- Database ---
DATABASE_URL="postgresql://aryora_user:password@localhost:5432/aryora_db?schema=public"

# --- Auth ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_REFRESH_EXPIRES_IN=30d

# --- Email (order confirmations, OTP) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=aryora.legacy@hotmail.com
SMTP_PASS=replace_with_email_app_password
SMTP_FROM="Aryora <aryora.legacy@hotmail.com>"

# --- Google Sheets lead sync (recommended path) ---
# Create a Google Cloud service account, enable Sheets API,
# share the target spreadsheet with the service account email.
GOOGLE_SHEETS_ENABLED=true
GOOGLE_SHEETS_SPREADSHEET_ID=replace_with_spreadsheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=replace@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace\n-----END PRIVATE KEY-----\n"

# --- Microsoft OneDrive/Excel lead sync (alternative path) ---
# Register an app in Azure AD, grant Files.ReadWrite + offline_access,
# generate a refresh token once via OAuth and store it here.
ONEDRIVE_SHEETS_ENABLED=false
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REFRESH_TOKEN=
MS_EXCEL_FILE_PATH=/Aryora/aryora-leads.xlsx
MS_EXCEL_TABLE_NAME=LeadsTable

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
